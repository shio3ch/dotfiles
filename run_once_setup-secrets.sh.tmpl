#!/bin/bash
set -e

SECRETS_DIR="$HOME/.secrets"

echo "=== Setting up secrets directory ==="
mkdir -p "$SECRETS_DIR"
chmod 700 "$SECRETS_DIR"
echo "  Created: $SECRETS_DIR (mode 700)"

TEMPLATE_SRC="{{ .chezmoi.sourceDir }}/mac/secrets/example.sh.template"
TEMPLATE_DEST="$SECRETS_DIR/example.sh.template"

if [ -f "$TEMPLATE_SRC" ] && [ ! -e "$TEMPLATE_DEST" ]; then
    cp "$TEMPLATE_SRC" "$TEMPLATE_DEST"
    chmod 600 "$TEMPLATE_DEST"
    echo "  Copied: $TEMPLATE_DEST"
fi

echo "Done."
echo "Next steps:"
echo "  1. Copy $SECRETS_DIR/example.sh.template to $SECRETS_DIR/<name>.sh"
echo "  2. Edit the file to add your API keys"
